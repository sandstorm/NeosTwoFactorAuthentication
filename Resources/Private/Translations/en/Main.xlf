<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="" product-name="Sandstorm.NeosTwoFactorAuthentication" source-language="en" datatype="plaintext">
    <body>
      <trans-unit id="login.otp.label" xml:space="preserve">
        <source>Enter the verification code from your authenticator app to complete login.</source>
      </trans-unit>
      <trans-unit id="otp-placeholder" xml:space="preserve">
        <source>Verification code from your app</source>
      </trans-unit>
      <trans-unit id="form.step.setup" xml:space="preserve">
        <source>Set up your authenticator</source>
      </trans-unit>
      <trans-unit id="form.step.verify" xml:space="preserve">
        <source>Enter code from your app</source>
      </trans-unit>
      <trans-unit id="form.step.register" xml:space="preserve">
        <source>Register</source>
      </trans-unit>
      <trans-unit id="login.flashMessage.errorHeader" xml:space="preserve">
				<source>Error</source>
			</trans-unit>
      <trans-unit id="login.flashMessage.invalidOtp" xml:space="preserve">
				<source>The provided OTP is invalid.</source>
			</trans-unit>
      <trans-unit id="login.flashMessage.submittedOtpIncorrect" xml:space="preserve">
				<source>Submitted OTP was incorrect.</source>
			</trans-unit>
      <trans-unit id="login.flashMessage.successfullyRegisteredOtp" xml:space="preserve">
				<source>OTP was registered successfully.</source>
			</trans-unit>
      <trans-unit id="form.setup.qrcode.label" xml:space="preserve">
        <source>Scan QR code</source>
      </trans-unit>
      <trans-unit id="form.setup.manual.label" xml:space="preserve">
        <source>Can't scan? Enter key manually</source>
      </trans-unit>
      <trans-unit id="form.secret.show" xml:space="preserve">
        <source>Show Secret Key</source>
      </trans-unit>
      <trans-unit id="form.secret.copy" xml:space="preserve">
        <source>Copy</source>
      </trans-unit>
      <trans-unit id="form.secret.close" xml:space="preserve">
        <source>Close</source>
      </trans-unit>
      <trans-unit id="method.picker.intro" xml:space="preserve">
        <source>Choose how you'd like to set up your second factor.</source>
      </trans-unit>
      <trans-unit id="method.totp.label" xml:space="preserve">
        <source>Authenticator app</source>
      </trans-unit>
      <trans-unit id="method.totp.description" xml:space="preserve">
        <source>Use Google Authenticator, Authy, 1Password or any TOTP-compatible app on your phone.</source>
      </trans-unit>
      <trans-unit id="method.webauthn.label" xml:space="preserve">
        <source>Security key (Yubikey / WebAuthn)</source>
      </trans-unit>
      <trans-unit id="method.webauthn.description" xml:space="preserve">
        <source>Use a hardware security key such as a Yubikey, or another FIDO2 authenticator.</source>
      </trans-unit>
      <trans-unit id="webauthn.setup.intro" xml:space="preserve">
        <source>Plug in your security key and press the button below. When prompted, tap your key and enter its PIN if requested.</source>
      </trans-unit>
      <trans-unit id="webauthn.setup.button" xml:space="preserve">
        <source>Register security key</source>
      </trans-unit>
      <trans-unit id="webauthn.setup.success" xml:space="preserve">
        <source>Security key registered successfully.</source>
      </trans-unit>
      <trans-unit id="webauthn.setup.error.unsupported" xml:space="preserve">
        <source>Your browser does not support security keys.</source>
      </trans-unit>
      <trans-unit id="webauthn.setup.error.generic" xml:space="preserve">
        <source>Could not register security key. Please try again.</source>
      </trans-unit>
      <trans-unit id="webauthn.login.prompt" xml:space="preserve">
        <source>Touch your security key to continue.</source>
      </trans-unit>
      <trans-unit id="webauthn.login.button" xml:space="preserve">
        <source>Use security key</source>
      </trans-unit>
      <trans-unit id="webauthn.login.fallback-to-totp" xml:space="preserve">
        <source>Use a code from your authenticator app instead</source>
      </trans-unit>
      <trans-unit id="webauthn.login.error.generic" xml:space="preserve">
        <source>Could not verify your security key. Please try again.</source>
      </trans-unit>
      <trans-unit id="form.name.label" xml:space="preserve">
        <source>Name (optional)</source>
      </trans-unit>
    </body>
  </file>
</xliff>
